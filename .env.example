FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-me

# LLM provider
GENERATOR_PROVIDER=groq
GENERATOR_ALLOW_FALLBACK=false
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Firebase client config (used by frontend auth)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Optional integrations
VITE_ABSTRACT_API_KEY=your_abstract_api_key

# One-click deploy (Netlify)
NETLIFY_ACCESS_TOKEN=your_netlify_personal_access_token
NETLIFY_SITE_ID=your_netlify_site_id_or_name_or_netlify_app_url
